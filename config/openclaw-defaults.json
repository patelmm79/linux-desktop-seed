{
  "$schema": "https://docs.openclaw.ai/schema.json",
  "meta": {
    "lastTouchedVersion": "2026.3.28",
    "lastTouchedAt": "2026-04-06T00:00:00Z"
  },
  "agents": {
    "defaults": {
      "model": "openrouter/minimax/MiniMax-M2.7",
      "compaction": {
        "mode": "default",
        "reserveTokens": 40000,
        "keepRecentTokens": 8000,
        "reserveTokensFloor": 40000,
        "maxHistoryShare": 0.25
      },
      "maxConcurrent": 2,
      "subagents": {
        "maxConcurrent": 4
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "REPLACE_WITH_DISCORD_BOT_TOKEN",
      "groupPolicy": "open",
      "streaming": "off"
    }
  },
  "gateway": {
    "mode": "local"
  }
}
