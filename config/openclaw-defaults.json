{
  "$schema": "https://docs.openclaw.ai/schema.json",
  "meta": {
    "lastTouchedVersion": "2026.3.28",
    "lastTouchedAt": "2026-04-07T22:00:00Z"
  },
  "models": {
    "mode": "merge",
    "providers": {
      "openrouter": {
        "apiKey": { "source": "env", "id": "OPENROUTER_API_KEY" }
      }
    }
  },
  "agents": {
    "defaults": {
      "model": "openrouter/minimax/MiniMax-M2.7",
      "compaction": {
        "mode": "default",
        "reserveTokens": 20000,
        "keepRecentTokens": 4000,
        "reserveTokensFloor": 20000,
        "maxHistoryShare": 0.02
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 4
      }
    }
  },
  "messages": {
    "ackReactionScope": "all"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "REPLACE_WITH_DISCORD_BOT_TOKEN",
      "groupPolicy": "open",
      "streaming": true
    }
  },
  "gateway": {
    "mode": "local"
  }
}
